  "keyFeatures": [
    "Multi-tenant identity infrastructure with Instances and Organizations",
    "OpenID Connect and SAML 2.0 authentication",
    "Passkeys (FIDO2/WebAuthn) and MFA support",
    "Actions and webhooks for custom flows",
    "SCIM 2.0 server for user provisioning",
    "Self-hosted and cloud deployment options",
    "Event-sourced audit trail",
    "Role-based access control (RBAC)",
    "Identity brokering with external IdPs",
    "Customizable login UI and branding"
  ],
  "publicApiSurface": [
    "User Service (Create, Update, Delete, List users)",
    "Organization Service (Manage organizations)",
    "Project Service (Manage projects and applications)",
    "Application Service (OIDC, SAML, API apps)",
    "Session Service (Session management)",
    "Action Service (Custom webhooks and code)",
    "IDP Service (External identity providers)",
    "Admin Service (Instance and system management)",
    "Auth Service (Authentication endpoints)",
    "Settings Service (Policies and configurations)",
    "Feature Service (Feature flags)",
    "Metadata Service (Custom metadata)",
    "Authorization Service (Permission checks)",
    "OIDC endpoints (/oauth/v2/authorize, /oauth/v2/token)",
    "SAML endpoints (/saml/v2/SSO, /saml/v2/metadata)",
    "SCIM 2.0 endpoints (/scim/v2/Users, /scim/v2/Groups)"
  ]
}
